            "name": "Check Pagination",
            "parameters": {
                "jsCode": "// BANCO DE PROMPTS — Controle de paginação\nconst items = $input.all();\nlet hasMore = false;\nlet nextPage = 1;\n\nfor (const item of items) {\n  const meta = item.json._meta;\n  if (meta) {\n    hasMore = meta.hasMore;\n    nextPage = meta.nextPage;\n    break;\n  }\n}\n\nconst maxPages = 1;\nconst dentroDoLimite = nextPage <= maxPages;\n\nreturn [{\n  json: {\n    page: nextPage,\n    hasMore: hasMore,\n    continue: hasMore === true && dentroDoLimite\n  }\n}];"
            },
