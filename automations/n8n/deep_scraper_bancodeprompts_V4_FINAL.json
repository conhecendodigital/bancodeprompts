        {
            "id": "a1b2c3d4-0021",
            "name": "Extrair Model Name",
            "parameters": {
                "jsCode": "// BANCO DE PROMPTS — Extrai model_name da API de detalhes\nconst items = $input.all();\n\nreturn items.map(item => {\n  const json = item.json;\n  \n  if (json._skip || json._done || json.error) {\n    return item;\n  }\n  \n  const modelName = json.model || json.tool || json.generator || json.modelName || json.ai_model || null;\n  \n  return {\n    json: {\n      original_id: json.original_id || json.id,\n      title: json.title,\n      full_prompt: json.full_prompt || json.prompt,\n      image_url: json.image_url || json.image || null,\n      author_name: json.author_name || json.creatorName || null,\n      tags: json.tags || [],\n      source_url: json.source_url || `https://www.bananaprompts.xyz/prompts/${json.original_id || json.id}`,\n      model_name: modelName,\n      _meta: json._meta || {}\n    }\n  };\n});"
            },
            "position": [
                1296,
                0
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
