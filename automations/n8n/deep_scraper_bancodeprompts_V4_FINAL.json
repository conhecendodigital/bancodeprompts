        {
            "id": "a1b2c3d4-0004",
            "name": "Filtrar & Transformar",
            "parameters": {
                "jsCode": "// BANCO DE PROMPTS — Filtragem e transformação\nconst input = $input.first().json;\nconst items = input.items || [];\nconst hasMore = input.hasMore || false;\nconst currentPage = input.offset !== undefined ? Math.floor(input.offset / 100) + 1 : 1;\n\nconst freePrompts = items.filter(item => !item.isPremium && item.prompt && item.prompt.trim() !== '');\n\nconst transformed = freePrompts.map(item => ({\n  json: {\n    original_id: item.id,\n    title: item.title,\n    full_prompt: item.prompt,\n    image_url: item.image || null,\n    author_name: item.creatorName || null,\n    tags: item.tags || [],\n    source_url: `https://www.bananaprompts.xyz/prompts/${item.id}`,\n    _meta: {\n      hasMore: hasMore,\n      nextPage: currentPage + 1,\n      processedInBatch: freePrompts.length\n    }\n  }\n}));\n\nif (transformed.length === 0 && hasMore) {\n  return [{ json: { _skip: true, _meta: { hasMore: true, nextPage: currentPage + 1, processedInBatch: 0 } } }];\n}\n\nif (transformed.length === 0 && !hasMore) {\n  return [{ json: { _done: true, _meta: { hasMore: false } } }];\n}\n\nreturn transformed;"
            },
            "position": [
                784,
                0
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
