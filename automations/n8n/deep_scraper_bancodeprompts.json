            ],
            "type": "n8n-nodes-base.supabase",
            "typeVersion": 1
        },
        {
            "id": "a1b2c3d4-0007",
            "name": "Check Pagination",
            "parameters": {
                "jsCode": "// BANCO DE PROMPTS — Controle de paginação\n// Recebe itens de duas fontes:\n// 1. Salvar no Supabase (itens válidos salvos)\n// 2. Tem Original ID? → False (itens _skip/_done com _meta)\n\nconst items = $input.all();\nlet hasMore = false;\nlet nextPage = 1;\n\n// Busca _meta em qualquer item recebido\nfor (const item of items) {\n  const meta = item.json._meta;\n  if (meta) {\n    hasMore = meta.hasMore;\n    nextPage = meta.nextPage;\n    break;\n  }\n}\n\n// LIMITE DE SEGURANÇA — Crescimento Controlado\nconst maxPages = 1;\nconst dentroDoLimite = nextPage <= maxPages;\n\nreturn [{\n  json: {\n    page: nextPage,\n    hasMore: hasMore,\n    continue: hasMore === true && dentroDoLimite\n  }\n}];"
            },
            "position": [
                1560,
                0
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
        {
            "id": "a1b2c3d4-0008",
            "name": "Mais Páginas?",
            "parameters": {
                "conditions": {
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "cond_continue",
                            "leftValue": "={{ $json.continue }}",
                            "operator": {
                                "operation": "true",
                                "singleValue": true,
                                "type": "boolean"
                            },
                            "rightValue": ""
                        }
                    ],
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict",
                        "version": 3
                    }
                },
                "options": {}
            },
