            ],
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.3
        },
        {
            "id": "a1b2c3d4-0006",
            "name": "Salvar no Supabase",
            "credentials": {
                "supabaseApi": {
                    "id": "ta1XyquWeL2aUlgz",
                    "name": "bancodeprompts"
                }
            },
            "parameters": {
                "operation": "create",
                "tableId": "prompts_vault",
                "dataToSend": "autoMapInputData",
                "inputsToIgnore": "_meta"
            },
            "position": [
